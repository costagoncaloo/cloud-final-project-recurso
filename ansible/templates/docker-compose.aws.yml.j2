services:
  catalog-service:
    image: ${IMAGE_REGISTRY}/catalog-service:${IMAGE_TAG:-latest}
    env_file: /opt/cloud-ecommerce/app.env
    environment:
      DATABASE_URL: jdbc:postgresql://${DB_HOST}:5432/${DB_NAME}
      DATABASE_USERNAME: ${DB_USERNAME}
      DATABASE_PASSWORD: ${DB_PASSWORD}
    ports:
      - "8081:8081"
    restart: unless-stopped

  order-service:
    image: ${IMAGE_REGISTRY}/order-service:${IMAGE_TAG:-latest}
    env_file: /opt/cloud-ecommerce/app.env
    environment:
      DATABASE_URL: jdbc:postgresql://${DB_HOST}:5432/${DB_NAME}
      DATABASE_USERNAME: ${DB_USERNAME}
      DATABASE_PASSWORD: ${DB_PASSWORD}
      CATALOG_SERVICE_URL: http://catalog-service:8081
      SQS_QUEUE_URL: ${SQS_QUEUE_URL}
      AWS_REGION: ${AWS_REGION}
    ports:
      - "8082:8082"
    restart: unless-stopped

  notification-service:
    image: ${IMAGE_REGISTRY}/notification-service:${IMAGE_TAG:-latest}
    env_file: /opt/cloud-ecommerce/app.env
    environment:
      SQS_QUEUE_URL: ${SQS_QUEUE_URL}
      AWS_REGION: ${AWS_REGION}
    ports:
      - "8083:8083"
    restart: unless-stopped
